    "author": "Venkatesh Sanku",
    "version": (3,0,0),
    "blender": (5,0,1),
    "location": "View3D > Sidebar > Venky Anim Toolz",
    "description": "Professional Root Motion Extractor for Rigify",
    "category": "Animation",
