RETARGET_ID = "_RM"

class BindConstraintsOperator(bpy.types.Operator):
    bl_idname = "simple_retarget.bind_constraints"
    bl_label = "Bind Constraints"
    
    def execute(self, context):
        props = context.scene.simple_retarget
        source_armature = props.source_armature
        target_armature = props.target_armature
        root_bone_name = props.root_bone

        # Minimal check: Ensure source and target armatures are not None
        if not source_armature:
            self.report({'WARNING'}, "Source Armature is not assigned.")
            return {'CANCELLED'}
        if not target_armature:
            self.report({'WARNING'}, "Target Armature is not assigned.")
            return {'CANCELLED'}

        # Ensure we're in Object mode
        if bpy.context.mode == 'POSE':
            bpy.ops.object.mode_set(mode='OBJECT')

        # Make the target rig active and go to Pose mode
        bpy.context.view_layer.objects.active = target_armature
        bpy.ops.object.mode_set(mode='POSE')

        # Remove all keyframes from target armature bones
        if target_armature.animation_data and target_armature.animation_data.action:
            action = target_armature.animation_data.action
            for bone in target_armature.pose.bones:
                for fcurve in action.fcurves:
                    if fcurve.data_path.startswith(f'pose.bones["{bone.name}"]'):
                        action.fcurves.remove(fcurve)

        # Reset the transforms of target armature bones
        bpy.ops.pose.select_all(action='SELECT')
        bpy.ops.pose.rot_clear()
        bpy.ops.pose.loc_clear()
        bpy.ops.pose.scale_clear()
        bpy.ops.object.mode_set(mode='OBJECT')

        # Check if a copy of the source armature already exists and delete it
        helper_armature = None
        for obj in bpy.data.objects:
            if obj.name.startswith(source_armature.name) and obj.name.endswith(RETARGET_ID):
                helper_armature = obj
                break

        if helper_armature:
            bpy.data.objects.remove(helper_armature, do_unlink=True)

        # Create a new copy of the source armature
        helper_armature = copy_rest_pose(context, source_armature)
        if not helper_armature:  # Check if duplication failed
            self.report({'WARNING'}, "Failed to copy source armature. It may be hidden or deleted.")
            return {'CANCELLED'}
        helper_armature.name = source_armature.name + RETARGET_ID

        # Parent the copied armature to the source armature
        bpy.ops.object.select_all(action='DESELECT')
        helper_armature.select_set(True)
        source_armature.select_set(True)
        bpy.context.view_layer.objects.active = source_armature
        bpy.ops.object.parent_set(type='OBJECT', keep_transform=True)

        # Hide the copied armature from the viewport
        helper_armature.hide_set(True)

        bpy.ops.object.mode_set(mode='OBJECT')
        bpy.context.view_layer.objects.active = target_armature
        bpy.ops.object.mode_set(mode='EDIT')

        bone_transforms = {}
        inv_helper = helper_armature.matrix_world.inverted()
        for bone in target_armature.data.edit_bones:
            bone.select = False
            head = inv_helper @ bone.head
            tail = inv_helper @ bone.tail
            roll = bone.roll
            bone_transforms[bone.name] = (head.copy(), tail.copy(), roll)

        bpy.ops.object.mode_set(mode='OBJECT')

        # Temporarily unhide the helper armature to enter edit mode
        helper_armature.hide_set(False)
        bpy.context.view_layer.objects.active = helper_armature
        bpy.ops.object.mode_set(mode='EDIT')

        for mapping in props.bone_mappings:
            source_bone_name = mapping.source_bone
            target_bone_name = mapping.target_bone
            if not source_bone_name or not target_bone_name:
                continue

            source_bone = helper_armature.data.edit_bones.get(source_bone_name)
            if not source_bone:
                continue

            if target_bone_name not in bone_transforms:
                continue
            head, tail, roll = bone_transforms[target_bone_name]

            new_bone_name = target_bone_name + RETARGET_ID
            if new_bone_name in helper_armature.data.edit_bones:
                helper_armature.data.edit_bones.remove(helper_armature.data.edit_bones[new_bone_name])
            new_bone = helper_armature.data.edit_bones.new(new_bone_name)
            new_bone.head = head
            new_bone.tail = tail
            new_bone.roll = roll
            new_bone.parent = source_bone

        bpy.ops.object.mode_set(mode='OBJECT')
        helper_armature.hide_set(True)

        bpy.context.view_layer.objects.active = target_armature
        bpy.ops.object.mode_set(mode='POSE')

        for bone in target_armature.pose.bones:
            for c in [con for con in bone.constraints if RETARGET_ID in con.name]:
                bone.constraints.remove(c)

        # Find the corresponding target bone for the root bone
        root_target_bone_name = None
        for mapping in props.bone_mappings:
            if mapping.source_bone == root_bone_name:
                root_target_bone_name = mapping.target_bone
                break

        if not root_target_bone_name:
            self.report({'WARNING'}, "Root bone is not properly mapped to a target bone")
            return {'CANCELLED'}

        for mapping in props.bone_mappings:
            source_bone_name = mapping.source_bone
            target_bone_name = mapping.target_bone
            if not source_bone_name or not target_bone_name:
                continue

            target_pose_bone = target_armature.pose.bones.get(target_bone_name)
            if not target_pose_bone:
                continue

            # Always add COPY_ROTATION constraint
            rot_con = target_pose_bone.constraints.new('COPY_ROTATION')
            rot_con.name = "Copy Rotation" + RETARGET_ID
            rot_con.target = helper_armature
            rot_con.subtarget = target_bone_name + RETARGET_ID
            rot_con.owner_space = 'POSE'
            rot_con.target_space = 'POSE'

            # Add COPY_LOCATION constraint only for the root bone
            if target_bone_name == root_target_bone_name:
                loc_con = target_pose_bone.constraints.new('COPY_LOCATION')
                loc_con.name = "Copy Location" + RETARGET_ID
                loc_con.target = helper_armature
                loc_con.subtarget = source_bone_name
                #loc_con.owner_space = 'POSE'
                #loc_con.target_space = 'POSE'

        bpy.ops.object.mode_set(mode='OBJECT')

        self.report({'INFO'}, "Retarget constraints applied successfully")
        return {'FINISHED'}

def copy_rest_pose(context, source_armature):
    bpy.ops.object.select_all(action='DESELECT')
    try:
        source_armature.select_set(True)
        bpy.context.view_layer.objects.active = source_armature
        bpy.ops.object.duplicate()
        helper_armature = bpy.context.object
        return helper_armature
    except RuntimeError as e:
        print(f"Error duplicating source armature: {e}")
        return None

class UnbindConstraintsOperator(bpy.types.Operator):
    bl_idname = "simple_retarget.unbind_constraints"
    bl_label = "Unbind Constraints"
    
    def execute(self, context):
        props = context.scene.simple_retarget
        target_armature = props.target_armature

        if not target_armature:
            self.report({'WARNING'}, "No Target Armature selected")
            return {'CANCELLED'}

        bpy.ops.object.mode_set(mode='OBJECT')
        bpy.context.view_layer.objects.active = target_armature
        bpy.ops.object.mode_set(mode='POSE')

        removed_count = 0
        for bone in target_armature.pose.bones:
            for con in [c for c in bone.constraints if RETARGET_ID in c.name]:
                bone.constraints.remove(con)
                removed_count += 1

        if props.source_armature:
            helper_name = props.source_armature.name + "_RM"
            if helper_name in bpy.data.objects:
                helper_obj = bpy.data.objects[helper_name]
                bpy.data.objects.remove(helper_obj, do_unlink=True)
                self.report({'INFO'}, f"Removed helper armature and {removed_count} constraints")
            else:
                self.report({'INFO'}, f"{removed_count} constraints removed")
        else:
            self.report({'INFO'}, f"{removed_count} constraints removed")

        # Switch back to Object mode after unbinding constraints
        bpy.ops.object.mode_set(mode='OBJECT')

        return {'FINISHED'}

