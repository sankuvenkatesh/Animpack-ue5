class SavePresetOperator(bpy.types.Operator):
    bl_idname = "simple_retarget.save_preset"
    bl_label = "Save Preset"
    bl_description = "Save the current bone mappings as a preset"

    filepath: bpy.props.StringProperty(subtype="FILE_PATH")

    def execute(self, context):
        props = context.scene.simple_retarget
        bone_mappings = props.bone_mappings

        # Ensure the file has a .txt extension
        if not self.filepath.endswith(".txt"):
            self.filepath += ".txt"

        # Write the bone mappings to the file
        with open(self.filepath, 'w') as file:
            for mapping in bone_mappings:
                file.write(f"{mapping.source_bone},{mapping.target_bone}\n")

        self.report({'INFO'}, f"Preset saved to {self.filepath}")
        return {'FINISHED'}

    def invoke(self, context, event):
        # Set default directory and filename
        self.filepath = os.path.join(preset_path, "preset.txt")
        context.window_manager.fileselect_add(self)
        return {'RUNNING_MODAL'}

class LoadPresetOperator(bpy.types.Operator):
    bl_idname = "simple_retarget.load_preset"
    bl_label = "Load Preset"
    bl_description = "Load a bone mappings preset from a file"

    filepath: bpy.props.StringProperty(subtype="FILE_PATH")
    directory: bpy.props.StringProperty(subtype="DIR_PATH")  # Directory for file browser

    def execute(self, context):
        props = context.scene.simple_retarget
        bone_mappings = props.bone_mappings
        source_armature = props.source_armature
        target_armature = props.target_armature

        # Clear existing bone mappings
        bone_mappings.clear()

        # Get the set of bone names from source and target armatures (if they exist)
        source_bone_names = set(source_armature.data.bones.keys()) if source_armature else set()
        target_bone_names = set(target_armature.data.bones.keys()) if target_armature else set()

        # Read the bone mappings from the file
        with open(self.filepath, 'r') as file:
            for line in file:
                source_bone, target_bone = line.strip().split(',')
                
                # Only add mapping if source bone exists in the current source armature
                if source_bone in source_bone_names:
                    new_mapping = bone_mappings.add()
                    new_mapping.source_bone = source_bone
                    
                    # Map target bone only if it exists in the current target armature
                    if target_bone in target_bone_names:
                        new_mapping.target_bone = target_bone
                    else:
                        new_mapping.target_bone = ""  # Leave unmapped if target bone doesn't exist

        self.report({'INFO'}, f"Preset loaded from {self.filepath} (filtered for existing bones)")
        return {'FINISHED'}

    def invoke(self, context, event):
        # Set the directory to the 'Presets' folder (assuming preset_path is defined elsewhere)
        self.directory = preset_path  # Ensure preset_path is defined in your script
        context.window_manager.fileselect_add(self)
        return {'RUNNING_MODAL'}

class SIMPLE_RETARGET_OT_HighlightBone(bpy.types.Operator):
    bl_idname = "simple_retarget.highlight_bone"
    bl_label = "Highlight Selected Bone"
    bl_description = "Highlight the selected bone in the bone mapping list (source or target)"

    def execute(self, context):
        props = context.scene.simple_retarget

        # Check if in Pose Mode
        if context.mode != 'POSE':
            self.report({'ERROR'}, "Please enter Pose Mode to select a bone.")
            return {'CANCELLED'}

        # Get the selected bone
        selected_bone = context.active_pose_bone
        if not selected_bone:
            self.report({'ERROR'}, "No bone selected. Please select a bone in Pose Mode.")
            return {'CANCELLED'}

        # Debug: Print the selected bone name
        print(f"Selected Bone: {selected_bone.name}")

        # Ensure the source and target armatures are set
        if not props.source_armature:
            self.report({'ERROR'}, "Source armature is not set.")
            return {'CANCELLED'}
        if not props.target_armature:
            self.report({'ERROR'}, "Target armature is not set.")
            return {'CANCELLED'}

        # Check if the selected bone belongs to either the source or target armature
        if selected_bone.id_data != props.source_armature and selected_bone.id_data != props.target_armature:
            self.report({'ERROR'}, "Selected bone does not belong to the source or target armature.")
            return {'CANCELLED'}

        # Iterate through the bone mappings
        for i, mapping in enumerate(props.bone_mappings):
            # Debug: Print the source and target bone names in the mapping
            print(f"Mapping {i}: Source Bone = {mapping.source_bone}, Target Bone = {mapping.target_bone}")

            # Compare the selected bone name with both source and target bones in the mapping
            if mapping.source_bone == selected_bone.name or mapping.target_bone == selected_bone.name:
                props.active_bone_index = i
                self.report({'INFO'}, f"Highlighted bone: {selected_bone.name}")
                return {'FINISHED'}

        # If no match is found
        self.report({'WARNING'}, "Selected bone not found in the bone mapping list.")
        return {'CANCELLED'}

