class SimpleRetargetImportFbx(Operator, ImportHelper):
    """Import mixamo FBX file, reset pose transforms, and apply object transforms for mixamo rigs"""
    bl_idname = "simple_retarget.import_fbx"
    bl_label = "Import FBX"
    bl_options = {'PRESET', 'UNDO'}

    # ImportHelper mixin class uses this
    filename_ext = ".fbx"

    filter_glob: StringProperty(
        default="*.fbx",
        options={'HIDDEN'},
        maxlen=255,
    )

    def execute(self, context):
        # Import the FBX file
        bpy.ops.import_scene.fbx(filepath=self.filepath)

        # Get the imported object (assuming it's the active object)
        imported_object = context.active_object

        if imported_object and imported_object.type == 'ARMATURE':
            # Switch to Pose Mode
            bpy.ops.object.mode_set(mode='POSE')

            # Reset location, rotation, and scale in Pose Mode
            bpy.ops.pose.loc_clear()
            bpy.ops.pose.rot_clear()
            bpy.ops.pose.scale_clear()

            # Switch back to Object Mode
            bpy.ops.object.mode_set(mode='OBJECT')

            # Scale animation curves to match the object's scale
            action = imported_object.animation_data.action
            scale = imported_object.scale
            for curve in action.fcurves:
                if curve.data_path.endswith('location'):
                    for kf in curve.keyframe_points:
                        if curve.array_index == 0:  # X axis
                            kf.co.y *= scale.x
                        elif curve.array_index == 1:  # Y axis
                            kf.co.y *= scale.y
                        elif curve.array_index == 2:  # Z axis
                            kf.co.y *= scale.z

            # Apply the transform in Object Mode
            bpy.ops.object.transform_apply(location=True, rotation=True, scale=True)
        else:
            self.report({'WARNING'}, "No armature found or selected. Transform not applied.")

        return {'FINISHED'}

def menu_func_import(self, context):
    self.layout.operator(SimpleRetargetImportFbx.bl_idname, text="RealMotionPro FBX Import (.fbx)")

