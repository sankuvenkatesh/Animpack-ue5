    bl_parent_id = "VIEW3D_PT_simple_retarget"

    def draw(self, context):
        layout = self.layout
        props = context.scene.simple_retarget_spacing

        if not context.selected_pose_bones:
            layout.label(text="Select target rig bones")
            return

        # Check if any selected bone has a valid mapped source bone in _RM rig
        has_valid_mapping = False
        rotation_modes = set()
        for bone in context.selected_pose_bones:
            rm_rig, rm_source_bone = get_mapped_rm_source_bone(context, bone)
            if rm_rig and rm_source_bone:
                has_valid_mapping = True
                rotation_modes.add(rm_source_bone.rotation_mode)

        if not has_valid_mapping:
            layout.label(text="No valid bone mappings found in _RM rig.")
            return

        # Display controls based on rotation modes present
        if 'QUATERNION' in rotation_modes:
            layout.label(text="Adjust Quaternion F-Curves for mapped _RM bones:")
            layout.prop(props, "rotation_w")
            layout.prop(props, "rotation_qx")
            layout.prop(props, "rotation_qy")
            layout.prop(props, "rotation_qz")
        
        if len(rotation_modes) > 1 or 'QUATERNION' not in rotation_modes:
            layout.label(text="Adjust Euler F-Curves for mapped _RM bones:")
            layout.prop(props, "rotation_x")
            layout.prop(props, "rotation_y")
            layout.prop(props, "rotation_z")

def get_last_keyframe(obj):
    if obj and obj.animation_data and obj.animation_data.action:
        return max((kp.co.x for fcurve in obj.animation_data.action.fcurves for kp in fcurve.keyframe_points), default=1)
    return 1

def bake_animation():
    props = bpy.context.scene.simple_retarget
    source_armature = props.source_armature
    target_armature = props.target_armature
    
    if not source_armature or not target_armature:
        print("Source or Target armature not set!")
        return
    
    bpy.ops.object.mode_set(mode='OBJECT')
    bpy.context.view_layer.objects.active = source_armature
    bpy.ops.object.mode_set(mode='POSE')
    bpy.ops.pose.select_all(action='SELECT')
    
    last_frame = get_last_keyframe(source_armature)
    
    bpy.ops.object.mode_set(mode='OBJECT')
    bpy.context.view_layer.objects.active = target_armature
    bpy.ops.object.mode_set(mode='POSE')
    
    # Deselect all bones first
    bpy.ops.pose.select_all(action='DESELECT')
    
    # Select only bones with constraints ending in "_RM"
    for bone in target_armature.pose.bones:
        for constraint in bone.constraints:
            if constraint.name.endswith("_RM"):
                bone.bone.select = True
                break  # Select the bone if it has at least one constraint ending with "_RM"
    
    # Bake only the selected bones
    bpy.ops.nla.bake(frame_start=1, frame_end=int(last_frame),
                      only_selected=True, visual_keying=True, 
                      clear_constraints=True, clean_curves=True)
    
    # Rename the baked action
    if target_armature.animation_data and target_armature.animation_data.action:
        baked_action = target_armature.animation_data.action
        new_action_name = f"{source_armature.name}_Bake"
        baked_action.name = new_action_name
        print(f"Renamed baked action to: {new_action_name}")
    
    # Remove only constraints that end with "_RM"
    for bone in target_armature.pose.bones:
        for constraint in bone.constraints:
            if constraint.name.endswith("_RM"):
                bone.constraints.remove(constraint)
    
    bpy.ops.object.mode_set(mode='OBJECT')
    
    for obj in bpy.data.objects:
        if obj.type == 'ARMATURE' and obj.name.endswith("_RM"):
            bpy.data.objects.remove(obj, do_unlink=True)
    
    print("Baking and cleanup complete!")

