class CalculateScaleOperator(bpy.types.Operator):
    bl_idname = "simple_retarget.calculate_scale"
    bl_label = "Calculate Scale"
    bl_description = "Scale the source rig to match the target rig"

    def execute(self, context):
        props = context.scene.simple_retarget
        source_rig = props.source_armature
        target_rig = props.target_armature

        if not source_rig or not target_rig:
            self.report({'WARNING'}, "Select both Source and Target Armatures")
            return {'CANCELLED'}

        source_rig.data.pose_position = 'REST'
        target_rig.data.pose_position = 'REST'

        def get_armature_dim(arm_obj):
            highest, lowest = float('-inf'), float('inf')
            for bone in arm_obj.pose.bones:
                z_head = (arm_obj.matrix_world @ bone.head)[2]
                z_tail = (arm_obj.matrix_world @ bone.tail)[2]
                highest = max(highest, z_head, z_tail)
                lowest = min(lowest, z_head, z_tail)
            return highest - lowest

        source_dim = get_armature_dim(source_rig)
        target_dim = get_armature_dim(target_rig)
        scale_factor = target_dim / source_dim
        
        if source_rig.animation_data and source_rig.animation_data.action:
            for fcurve in source_rig.animation_data.action.fcurves:
                if fcurve.data_path == "scale":
                    source_rig.animation_data.action.fcurves.remove(fcurve)
        
        source_rig.scale *= scale_factor * 1 
        source_rig.data.pose_position = 'POSE'
        target_rig.data.pose_position = 'POSE'
        
        return {'FINISHED'}

