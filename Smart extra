class GRAPH_OT_detect(bpy.types.Operator):

    bl_idname="graph.detect_bad_rotations"
    bl_label="Detect Bad Rotation Curves"
    bl_options={'REGISTER','UNDO'}

    def execute(self,context):

        curves=get_graph_fcurves(context)

        bad=detect_bad_rotation_keys(curves)

        for fc in curves:

            for kp in fc.keyframe_points:

                if int(round(kp.co[0])) in bad:
                    kp.select_control_point=True

        return{'FINISHED'}


