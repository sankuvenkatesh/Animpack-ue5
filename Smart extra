class GRAPH_OT_smart_euler(bpy.types.Operator):

    bl_idname="graph.smart_euler_filter"
    bl_label="Smart Euler Filter"
    bl_options={'REGISTER','UNDO'}

    def execute(self,context):

        curves=get_graph_fcurves(context)

        k=collect_keyframes(curves)

        fixed=smart_euler_filter(k)

        apply_keyframes(curves,fixed)

        return{'FINISHED'}


