# ---------------------------------------------------------
# Detect Bad Keys
# ---------------------------------------------------------

def detect_bad_rotation_keys(curves):

    bad=set()

    for fc in curves:

        k=fc.keyframe_points

        for i in range(1,len(k)):

            a=k[i-1].co[1]
            b=k[i].co[1]

            if abs(b-a)>math.pi:
                bad.add(int(round(k[i].co[0])))

    return bad


