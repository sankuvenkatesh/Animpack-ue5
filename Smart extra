# ---------------------------------------------------------
# Utility
# ---------------------------------------------------------

def clamp(v, a, b):
    return max(a, min(v, b))

def get_graph_fcurves(context):

    fcurves = []

    try:
        selected = getattr(context, "selected_editable_fcurves", [])
        if selected:
            fcurves.extend(selected)
    except:
        pass

    try:
        obj = context.active_object
        if obj and obj.animation_data and obj.animation_data.action:
            fcurves.extend(obj.animation_data.action.fcurves)
    except:
        pass

    return list(set(fcurves))


# ---------------------------------------------------------
# Rotation Utilities
# ---------------------------------------------------------

def nearest_equivalent_euler(a1, a2):

    twopi = 2 * math.pi

    while a2 - a1 > math.pi:
        a2 -= twopi

    while a2 - a1 < -math.pi:
        a2 += twopi

    return a2


def strong_unwrap_angle(prev, current):

    twopi = 2 * math.pi
    diff = current - prev

    while diff > math.pi:
        current -= twopi
        diff = current - prev

    while diff < -math.pi:
        current += twopi
        diff = current - prev

    return current


def reduce_gimbal_spikes(values):

    fixed = values[:]

    for i in range(1, len(values)-1):

        p = values[i-1]
        c = values[i]
        n = values[i+1]

        if p is None or c is None or n is None:
            continue

        avg = (p+n)/2

        if abs(c-avg) > math.pi:
            fixed[i] = avg

    return fixed


# ---------------------------------------------------------
# Keyframe Helpers
# ---------------------------------------------------------

def get_fcurve_keyframe_map(fc):
    return {int(round(k.co[0])): k for k in fc.keyframe_points}

def collect_keyframes(curves):

    maps = [get_fcurve_keyframe_map(fc) for fc in curves]

    frames = sorted({f for m in maps for f in m})

    data = []

    for f in frames:

        values = []
        handles = []

        for m in maps:

            kp = m.get(f)

            if kp:
                values.append(kp.co[1])
                handles.append({
                    "hl": kp.handle_left.copy(),
                    "hr": kp.handle_right.copy(),
                    "hlt": kp.handle_left_type,
                    "hrt": kp.handle_right_type
                })
            else:
                values.append(None)
                handles.append(None)

        data.append({"frame":f,"value":values,"handles":handles})

    return data


def apply_keyframes(curves,data):

    for axis,fc in enumerate(curves):

        m = get_fcurve_keyframe_map(fc)

        for info in data:

            f = info["frame"]
            v = info["value"][axis]

            if v is None:
                continue

            kp = m.get(f)

            if kp:

                kp.co[1] = v

        fc.update()


# ---------------------------------------------------------
# Filters
# ---------------------------------------------------------

def smart_euler_filter(keyframes):

    out=[]
    prev=None

    for k in keyframes:

        e=k["value"]

        if prev is None:
            fixed=list(e)

        else:
            fixed=[]

            for i in range(len(e)):

                if e[i] is None:
                    fixed.append(prev[i])
                elif prev[i] is None:
                    fixed.append(e[i])
                else:
                    fixed.append(nearest_equivalent_euler(prev[i],e[i]))

        prev=fixed

        out.append({
            "frame":k["frame"],
            "value":fixed,
            "handles":k["handles"]
        })

    return out


