def get_last_keyframe(obj):
    if obj and obj.animation_data and obj.animation_data.action:
        return max((kp.co.x for fcurve in obj.animation_data.action.fcurves for kp in fcurve.keyframe_points), default=1)
    return 1


def bake_animation():
    props = bpy.context.scene.simple_retarget
    source_armature = props.source_armature
    target_armature = props.target_armature
    
    if not source_armature or not target_armature:
        print("Source or Target armature not set!")
        return
    
    safe_mode_set('OBJECT')
    bpy.context.view_layer.objects.active = source_armature
    safe_mode_set('POSE')
    bpy.ops.pose.select_all(action='SELECT')
    
    last_frame = get_last_keyframe(source_armature)
    
    safe_mode_set('OBJECT')
    bpy.context.view_layer.objects.active = target_armature
    safe_mode_set('POSE')
    
    bpy.ops.pose.select_all(action='DESELECT')
    
    for bone in target_armature.pose.bones:
        for constraint in bone.constraints:
            if constraint.name.endswith("_RM"):
                bone.bone.select = True
                break
    
    bpy.ops.nla.bake(frame_start=1, frame_end=int(last_frame),
                      only_selected=True, visual_keying=True, 
                      clear_constraints=True, clean_curves=True, bake_types={'POSE'})
    
    for bone in target_armature.pose.bones:
        for constraint in list(bone.constraints):  # SAFE FIX
            if constraint.name.endswith("_RM"):
                bone.constraints.remove(constraint)
    
    safe_mode_set('OBJECT')


class SIMPLE_RETARGET_OT_BakeOperator(bpy.types.Operator):
    bl_idname = "simple_retarget.bake_animation"
    bl_label = "Bake Animation"

    def execute(self, context):
        bake_animation()
        return {'FINISHED'}


# ---------------- FBX ----------------

class SimpleRetargetImportFbx(Operator, ImportHelper):
    bl_idname = "simple_retarget.import_fbx"
    bl_label = "Import FBX"
    bl_options = {'PRESET', 'UNDO'}

    filename_ext = ".fbx"

    filter_glob: StringProperty(
        default="*.fbx",
        options={'HIDDEN'},
        maxlen=255,
    )

    def execute(self, context):
        bpy.ops.import_scene.fbx(filepath=self.filepath)

        imported_object = context.active_object

        if imported_object and imported_object.type == 'ARMATURE':

            safe_mode_set('POSE')
            bpy.ops.pose.loc_clear()
            bpy.ops.pose.rot_clear()
            bpy.ops.pose.scale_clear()

            safe_mode_set('OBJECT')

            action = safe_get_action(imported_object)
            if action:
                scale = imported_object.scale
                for curve in action.fcurves:
                    if curve.data_path.endswith('location'):
                        for kf in curve.keyframe_points:
                            if curve.array_index == 0:
                                kf.co.y *= scale.x
                            elif curve.array_index == 1:
                                kf.co.y *= scale.y
                            elif curve.array_index == 2:
                                kf.co.y *= scale.z

            bpy.ops.object.transform_apply(location=True, rotation=True, scale=True)

        else:
            self.report({'WARNING'}, "No armature found or selected.")

        return {'FINISHED'}


def menu_func_import(self, context):
    self.layout.operator(SimpleRetargetImportFbx.bl_idname, text="RealMotionPro FBX Import (.fbx)")


