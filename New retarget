def get_rm_fcurve(armature, bone_name, rotation_type, axis):
    if not armature.animation_data or not armature.animation_data.action:
        return None
    
    action = armature.animation_data.action

    if rotation_type == 'rotation_euler':
        data_path = f'pose.bones["{bone_name}"].rotation_euler'
        return action.fcurves.find(data_path, index=axis)

    elif rotation_type == 'rotation_quaternion':
        data_path = f'pose.bones["{bone_name}"].rotation_quaternion'
        return action.fcurves.find(data_path, index=axis)

    return None


def get_mapped_rm_source_bone(context, target_bone):
    props = context.scene.simple_retarget
    source_rig = props.source_armature
    target_rig = props.target_armature
    
    if not (source_rig and target_rig and target_bone.id_data == target_rig):
        return None, None
        
    source_bone_name = None
    for mapping in props.bone_mappings:
        if mapping.target_bone == target_bone.name:
            source_bone_name = mapping.source_bone
            break
    
    if not source_bone_name:
        return None, None
        
    rm_rig_name = source_rig.name + RETARGET_ID
    rm_rig = bpy.data.objects.get(rm_rig_name)
    
    if not rm_rig or rm_rig.type != 'ARMATURE':
        return None, None
        
    return rm_rig, rm_rig.pose.bones.get(source_bone_name)


def update_rotation_values(context, rotation_type, axis):
    props = context.scene.simple_retarget_spacing
    
    selected_bones = context.selected_pose_bones
    if not selected_bones:
        return

    if rotation_type == 'rotation_euler':
        current = getattr(props, f"rotation_{'xyz'[axis]}")
        previous = getattr(props, f"prev_rotation_{'xyz'[axis]}")
    elif rotation_type == 'rotation_quaternion':
        if axis == 0:
            current = props.rotation_w
            previous = props.prev_rotation_w
        else:
            suffix = ['qx', 'qy', 'qz'][axis - 1]
            current = getattr(props, f"rotation_{suffix}")
            previous = getattr(props, f"prev_rotation_{suffix}")
    else:
        return

    delta = current - previous

    for bone in selected_bones:
        rm_rig, rm_source_bone = get_mapped_rm_source_bone(context, bone)
        if rm_rig and rm_source_bone:
            fcurve = get_rm_fcurve(rm_rig, rm_source_bone.name, rotation_type, axis)
            if fcurve:
                for kp in fcurve.keyframe_points:
                    kp.co[1] += delta
                fcurve.update()

    if rotation_type == 'rotation_euler':
        setattr(props, f"prev_rotation_{'xyz'[axis]}", current)
    elif rotation_type == 'rotation_quaternion':
        if axis == 0:
            props.prev_rotation_w = current
        else:
            setattr(props, f"prev_rotation_{suffix}", current)

    if context.area:
        context.area.tag_redraw()


class SimpleRetargetSpacingProperties(bpy.types.PropertyGroup):
    rotation_x: bpy.props.FloatProperty(update=lambda s, c: update_rotation_values(c, 'rotation_euler', 0))
    rotation_y: bpy.props.FloatProperty(update=lambda s, c: update_rotation_values(c, 'rotation_euler', 1))
    rotation_z: bpy.props.FloatProperty(update=lambda s, c: update_rotation_values(c, 'rotation_euler', 2))
    rotation_w: bpy.props.FloatProperty(update=lambda s, c: update_rotation_values(c, 'rotation_quaternion', 0))
    rotation_qx: bpy.props.FloatProperty(update=lambda s, c: update_rotation_values(c, 'rotation_quaternion', 1))
    rotation_qy: bpy.props.FloatProperty(update=lambda s, c: update_rotation_values(c, 'rotation_quaternion', 2))
    rotation_qz: bpy.props.FloatProperty(update=lambda s, c: update_rotation_values(c, 'rotation_quaternion', 3))

